<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <!-- ── 자산 번호 입력 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="자산 번호 (asset_uid)"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_asset_uid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="BDT00001"
            android:inputType="textCapCharacters"
            android:maxLength="10"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tv_asset_uid_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="형식: [B|R|C|L|S][유형코드][5자리 숫자]"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- ── 전송 주기 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="전송 주기"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <Spinner
            android:id="@+id/spinner_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <!-- ── 버튼 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="시작"
                android:enabled="false"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_send_now"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="즉시 전송"
                android:enabled="false" />
        </LinearLayout>

        <!-- ── 로딩 ── -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- ── 구분선: 상태 정보 ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="상태 정보"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="연결 상태: -"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tv_asset_uid_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="자산 번호: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_interval"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="전송 주기: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_last_heartbeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="마지막 전송: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_send_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_agent_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="에이전트 버전: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- ── 구분선: OS 정보 (접기/펼치기) ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="28dp" />

        <LinearLayout
            android:id="@+id/header_os_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OS / 보안패치 정보"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_os_toggle_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_os_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_os_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OS 버전: -"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tv_os_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OS 상세: -"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tv_os_build"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="빌드 번호: -"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tv_os_security_patch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보안패치 (Android): -"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tv_os_vendor_patch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="벤더 패치: -"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tv_os_ubr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UBR: -"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_os_kb_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="적용 KB: -"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_os_patch_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- ── 구분선: 사용자 확인 ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사용자 확인"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사용자 이름: -"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tv_employee_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사번: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_last_verified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="마지막 확인: -"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tv_verification_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="상태: 미확인"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/btn_verify"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="사용자 확인하기"
            android:enabled="false"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
