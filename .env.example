############################################################
# OAManager v1 - Docker 환경변수
# 도메인: terraforming.info
############################################################

# ── 도메인 ──────────────────────────────────────────────
OA_DOMAIN=terraforming.info

# ── Supabase 공개 URL ──────────────────────────────────
# Traefik이 SSL 처리하므로 https 사용
OA_SUPABASE_PUBLIC_URL=https://api.terraforming.info
OA_SITE_URL=https://terraforming.info
OA_ADDITIONAL_REDIRECT_URLS=https://terraforming.info

# ── PostgreSQL ─────────────────────────────────────────
OA_POSTGRES_PASSWORD=your-super-secret-and-long-postgres-passwordoa

# ── JWT ────────────────────────────────────────────────
# 최소 32자 이상의 시크릿 키 (COSMOSX와 반드시 다른 값 사용)
OA_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-longoa
OA_JWT_EXPIRY=3600

# ── Supabase API Keys ─────────────────────────────────
# supabase 키 생성: https://supabase.com/docs/guides/self-hosting#api-keys
OA_ANON_KEY=your-anon-key
OA_SERVICE_ROLE_KEY=your-service-role-key

# ── Dashboard ──────────────────────────────────────────
OA_DASHBOARD_USERNAME=admin
OA_DASHBOARD_PASSWORD=your-dashboard-passwordoa

# ── Realtime ───────────────────────────────────────────
OA_SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters-long-for-realtime-service

# ── Meta ───────────────────────────────────────────────
OA_PG_META_CRYPTO_KEY=your-pg-meta-crypto-key

# ── Email (옵션) ───────────────────────────────────────
OA_ENABLE_EMAIL_SIGNUP=true
OA_ENABLE_EMAIL_AUTOCONFIRM=true
OA_DISABLE_SIGNUP=false
OA_SMTP_ADMIN_EMAIL=
OA_SMTP_HOST=
OA_SMTP_PORT=587
OA_SMTP_USER=
OA_SMTP_PASS=
OA_SMTP_SENDER_NAME=OAManager

# ── Edge Functions ─────────────────────────────────────
OA_FUNCTIONS_VERIFY_JWT=false

# ── PostgREST ──────────────────────────────────────────
OA_PGRST_DB_SCHEMAS=public
